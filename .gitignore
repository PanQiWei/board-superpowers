# OS
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Env / secrets
.env
.env.*
!.env.example

# Node (in case any skill or script introduces it later)
node_modules/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Per-project Claude Code artifacts (local, per-user).
# .claude/settings.json and .claude-plugin/marketplace.json are
# team-shared (this repo dogfoods its own plugin), so they stay tracked.
.claude/settings.local.json
.claude/cache/
.claude/logs/
.claude/tmp/

# board-superpowers local state (claim markers are per-session)
.board-superpowers/claims/

# board-superpowers Consumer session plan briefs — scratch input that
# the Consumer hands to subagent-driven-development. Not a durable
# artifact: the card body on GitHub is the source of truth, and the
# plan brief is just a reformat for the execution skill. Keeping it
# local prevents main from accumulating one file per merged card.
docs/board-superpowers/plans/

# Implementation-facing plans — Producer-side intermediate artifacts
# (brainstorming output, plan-eng-review notes, per-card body drafts
# before `gh issue create`). One subdirectory per feature, e.g.
# docs/plans/bootstrap/. Lifecycle: tied to a single Manager → Consumer
# cycle for one feature; pruned after the feature lands. Spec lives
# under docs/architecture/ — these are scaffolding, not source of truth.
# See AGENTS.md § "Implementation-facing plans (`docs/plans/`)".
docs/plans/

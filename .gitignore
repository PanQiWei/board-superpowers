node_modules/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Per-project Claude Code artifacts (local, per-user).
# .claude/settings.json and .claude-plugin/marketplace.json are
# team-shared (this repo dogfoods its own plugin), so they stay tracked.
.claude/settings.local.json
.claude/cache/
.claude/logs/
.claude/tmp/

# board-superpowers local state (claim markers are per-session)
.board-superpowers/claims/

# board-superpowers Consumer session plan briefs — scratch input that
# the Consumer hands to subagent-driven-development. Not a durable
# artifact: the card body on GitHub is the source of truth, and the
# plan brief is just a reformat for the execution skill. Keeping it
# local prevents main from accumulating one file per merged card.
docs/board-superpowers/plans/
